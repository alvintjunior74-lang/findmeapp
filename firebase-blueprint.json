{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the FindMe application",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "username": { "type": "string" },
        "trustScore": { "type": "number" },
        "joinedAt": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "therapist"] },
        "phone": { "type": "string" }
      },
      "required": ["email", "username", "trustScore", "joinedAt", "role"]
    },
    "Post": {
      "title": "Post",
      "description": "An emotional share or update",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorRole": { "type": "string", "enum": ["user", "therapist"] },
        "content": { "type": "string" },
        "emotion": { "type": "string", "enum": ["happy", "sad", "angry", "tired", "anxious", "neutral", "hopeful"] },
        "timestamp": { "type": "number" },
        "supportCount": { "type": "number" },
        "likeCount": { "type": "number" },
        "hugCount": { "type": "number" },
        "lastEditedAt": { "type": "number" },
        "isAnonymous": { "type": "boolean" }
      },
      "required": ["authorId", "content", "emotion", "timestamp", "supportCount", "likeCount", "hugCount", "isAnonymous"]
    },
    "TherapistAdvice": {
      "title": "TherapistAdvice",
      "description": "Professional support from a therapist",
      "type": "object",
      "properties": {
        "therapistId": { "type": "string" },
        "therapistName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["therapistId", "therapistName", "content", "createdAt"]
    },
    "PostHistory": {
      "title": "PostHistory",
      "description": "Historical version of a post",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "emotion": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "editedAt": { "type": "number" },
        "authorId": { "type": "string" }
      },
      "required": ["content", "emotion", "isAnonymous", "editedAt", "authorId"]
    },
    "ChatRoom": {
      "title": "ChatRoom",
      "description": "A global or private trust circle",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat room (encrypted string simulation)",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "number" },
        "postId": { "type": "string" }
      },
      "required": ["senderId", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles keyed by auth UID"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Global feed of emotional shares"
    },
    "/posts/{postId}/history/{historyId}": {
      "schema": { "$ref": "#/entities/PostHistory" },
      "description": "Edit history for a post"
    },
    "/posts/{postId}/therapistAdvice/{adviceId}": {
      "schema": { "$ref": "#/entities/TherapistAdvice" },
      "description": "Professional advice given by therapists"
    },
    "/chatRooms/{roomId}": {
      "schema": { "$ref": "#/entities/ChatRoom" },
      "description": "Collection of trust circles"
    },
    "/chatRooms/{roomId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages within a specific room"
    }
  }
}
