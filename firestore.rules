rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // USER RULES
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'username', 'trustScore', 'joinedAt', 'role']) &&
             data.keys().size() == 5 &&
             data.email is string && data.email.size() <= 150 &&
             data.username is string && data.username.size() > 0 && data.username.size() <= 30 &&
             data.trustScore is number &&
             data.joinedAt is timestamp &&
             data.role is string && data.role in ['user', 'therapist'];
    }

    function isTherapist() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'therapist';
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.auth.uid == userId &&
                       isValidId(userId) &&
                       isValidUser(incoming()) &&
                       incoming().trustScore == 0 &&
                       incoming().joinedAt == request.time;
      allow update: if isSignedIn() &&
                       request.auth.uid == userId &&
                       isValidUser(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['username', 'trustScore']) &&
                       incoming().joinedAt == existing().joinedAt &&
                       incoming().email == existing().email;
    }

    // POST RULES
    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorRole', 'content', 'emotion', 'timestamp', 'supportCount', 'likeCount', 'hugCount', 'isAnonymous']) &&
             data.keys().size() >= 9 && data.keys().size() <= 10 &&
             data.authorId is string &&
             data.authorRole is string && data.authorRole in ['user', 'therapist'] &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 1000 &&
             data.emotion is string && data.emotion in ['happy', 'sad', 'angry', 'tired', 'anxious', 'neutral', 'hopeful'] &&
             data.timestamp is timestamp &&
             data.supportCount is number &&
             data.likeCount is number &&
             data.hugCount is number &&
             data.isAnonymous is bool &&
             (!data.keys().hasAny(['lastEditedAt']) || data.lastEditedAt is timestamp);
    }

    match /posts/{postId} {
      allow get: if isSignedIn() && (existing().authorId == request.auth.uid || existing().isAnonymous == true);
      allow list: if isSignedIn() && (existing().authorId == request.auth.uid || existing().isAnonymous == true);
      allow create: if isSignedIn() &&
                       isValidId(postId) &&
                       isValidPost(incoming()) &&
                       incoming().authorId == request.auth.uid &&
                       incoming().timestamp == request.time &&
                       incoming().supportCount == 0 &&
                       exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update: if isSignedIn() &&
                       isValidPost(incoming()) &&
                       (
                         // Anyone can react
                         (
                           incoming().diff(existing()).affectedKeys().hasOnly(['supportCount', 'likeCount', 'hugCount']) &&
                           (incoming().supportCount == existing().supportCount + 1 || incoming().supportCount == existing().supportCount) &&
                           (incoming().likeCount == existing().likeCount + 1 || incoming().likeCount == existing().likeCount) &&
                           (incoming().hugCount == existing().hugCount + 1 || incoming().hugCount == existing().hugCount)
                         ) ||
                         // Author can edit
                         (
                           request.auth.uid == existing().authorId && 
                           incoming().diff(existing()).affectedKeys().hasOnly(['content', 'emotion', 'isAnonymous', 'lastEditedAt']) &&
                           incoming().lastEditedAt == request.time
                         )
                       ) &&
                       incoming().authorId == existing().authorId &&
                       incoming().timestamp == existing().timestamp;
      allow delete: if isSignedIn() && 
                       request.auth.uid == existing().authorId;

      match /history/{historyId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid);
        allow create: if isSignedIn() && 
                         request.auth.uid == get(/databases/$(database)/documents/posts/$(postId)).data.authorId &&
                         incoming().editedAt == request.time;
      }

      match /therapistAdvice/{adviceId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && 
                         isTherapist() &&
                         incoming().therapistId == request.auth.uid &&
                         incoming().createdAt == request.time;
      }
    }

    // CHAT ROOM RULES
    function isValidChatRoom(data) {
      return data.keys().hasAll(['name', 'createdAt', 'isDirect', 'participants']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.createdAt is timestamp &&
             data.isDirect is bool &&
             data.participants is list && data.participants.size() <= 20;
    }

    match /chatRooms/{roomId} {
      allow get: if isSignedIn() && (!existing().isDirect || request.auth.uid in existing().participants);
      allow list: if isSignedIn() && (!existing().isDirect || request.auth.uid in existing().participants);
      allow create: if isSignedIn() &&
                       isValidId(roomId) &&
                       isValidChatRoom(incoming()) &&
                       incoming().createdAt == request.time &&
                       (!incoming().isDirect || request.auth.uid in incoming().participants);
    }

    // MESSAGE RULES
    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'timestamp']) &&
             data.keys().size() >= 3 && data.keys().size() <= 5 &&
             data.senderId is string && data.senderId == request.auth.uid &&
             (!data.keys().hasAny(['senderName']) || data.senderName is string) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 2000 &&
             data.timestamp is timestamp &&
             (!data.keys().hasAny(['postId']) || data.postId is string);
    }

    match /chatRooms/{roomId}/messages/{messageId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/chatRooms/$(roomId));
      allow list: if isSignedIn() && exists(/databases/$(database)/documents/chatRooms/$(roomId));
      allow create: if isSignedIn() &&
                       isValidId(messageId) &&
                       isValidMessage(incoming()) &&
                       incoming().timestamp == request.time &&
                       exists(/databases/$(database)/documents/chatRooms/$(roomId)) &&
                       exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
  }
}
